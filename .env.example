# Searay — local environment.
# Copy to .env and fill in:  cp .env.example .env
# .env is gitignored and auto-loaded by every `uv run` command.

# Unleashed API — only needed to pull live data (Integration → API Access)
UNLEASHED_API_ID=
UNLEASHED_API_KEY=

# Data source: csv (default, the exports in Example Data/) or unleashed
# SEARAY_DATA_SOURCE=csv

# Optional: override the engine port (default 8000)
# PORT=8000
